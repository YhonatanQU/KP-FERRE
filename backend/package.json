{
  "name": "erp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:check": "tsx src/scripts/db-check.ts",
    "db:init:sql": "docker exec -i erp-postgres psql -U postgres -d erp_db -f prisma/sql/init.sql",
    "db:init": "npm run db:up && npm run db:check && npm run db:init:sql && npm run prisma:generate && npm run prisma:migrate -- --name init && npm run prisma:seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.1",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.7",
    "fastify": "^4.28.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.78",
    "prisma": "^5.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
